# Copy to `.dev.vars` for local dev (see README). On Vercel / Cloudflare, set these in the dashboard.
#
# Owner login at /admin/login — required for contract admin.
CONTRACT_ADMIN_PASSWORD=

# Signs the admin session cookie — at least 16 characters. Required for login to succeed.
CONTRACT_SESSION_SECRET=

# Postgres (Vercel) or omit when using Cloudflare D1 — see README.
# DATABASE_URL=
